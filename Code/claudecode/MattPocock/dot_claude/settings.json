{
  "permissions": {
    "allow": [
      "Bash(pip install *)",
      "Bash(pip install -e *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(streamlit run *)",
      "Read",
      "Write",
      "Edit"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd *)",
      "Bash(drop table *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(CLAUDE.local.md)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd $PROJECT_ROOT && python -m py_compile $CLAUDE_TOOL_OUTPUT_FILE 2>&1 || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd $PROJECT_ROOT && pytest tests/ -q --tb=no 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
