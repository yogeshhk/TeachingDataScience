{
  "mcp": {
    "github": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      }
    }
  },
  "permission": {
    "github_*": "ask",
    "bash": {
      "git push *": "ask",
      "git commit *": "allow",
      "git add *": "allow"
    }
  }
}